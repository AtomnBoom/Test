<Page x:Class="TestDmit.View.Pages.AddStudentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TestDmit.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddStudentPage" Background="White">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="15" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="15" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="15" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="1" Text="Введите ФИО" VerticalAlignment="Center" FontSize="28"/>
        <TextBox Name="NameTb" Grid.Row="1" Grid.Column="2" Height="60" VerticalAlignment="Center" FontSize="28"/>

        <TextBlock Grid.Row="3" Text="Группа" VerticalAlignment="Center" FontSize="28"/>
        <ComboBox Name="GroupCb" Grid.Row="3" Grid.Column="2" Height="60" Text="Группа" VerticalAlignment="Center" FontSize="28"/>

        <Button Grid.Row="5" Content="Добавить" FontSize="28" Click="Button_Click"/>
        <Button Grid.Row="5" Grid.Column="2" Content="Назад" FontSize="28" Click="Button_Click_1"/>
    </Grid>
</Page>
