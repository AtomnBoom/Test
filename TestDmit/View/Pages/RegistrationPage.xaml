<Page x:Class="TestDmit.View.Pages.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TestDmit.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegistrationPage">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="15" />
            <RowDefinition Height="50" />
            <RowDefinition Height="15" />
            <RowDefinition Height="50" />
            <RowDefinition Height="15" />
            <RowDefinition Height="50" />
            <RowDefinition Height="15" />
            <RowDefinition Height="50" />
            <RowDefinition Height="15" />
            <RowDefinition Height="50" />
            <RowDefinition Height="15" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <TextBlock Text="Выберите группу" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="28" Grid.Row="0"/>
        <ComboBox Name="GroupCb" Width="300" Height="50" Grid.Row="2" VerticalContentAlignment="Center" FontSize="20" SelectionChanged="GroupCb_SelectionChanged"/>

        <TextBlock Text="Выберите студента" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="28" Grid.Row="4"/>
        <ComboBox Name="StudentCb" Width="300" Height="50" Grid.Row="6" VerticalContentAlignment="Center" FontSize="20"/>
        
        <TextBlock Text="Выберите тест" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="28" Grid.Row="8"/>
        <ComboBox Name="TestCb" Width="300" Height="50" Grid.Row="10" VerticalContentAlignment="Center" FontSize="20"/>

        <Button Content="Начать" Grid.Row="12" Width="150" Height="40" VerticalAlignment="Top" Click="Button_Click"/>
    </Grid>
</Page>
