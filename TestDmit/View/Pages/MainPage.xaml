<Page x:Class="TestDmit.View.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TestDmit.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="50" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="50" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="15" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <TextBlock Text="Тесты по дисциплине" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="36" />
        <TextBlock Text='"Экономика отросли"' HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="36" Grid.Row="2"/>
        <Button Name="PreBtn" Content="Преподаватель" FontSize="28" Grid.Row="4" Width="300" Height="60" Click="PreBtn_Click"/>
        <Button Name="StuBtn" Content="Студент" FontSize="28" Grid.Row="6" Width="300" Height="60" Click="StuBtn_Click"/>
    </Grid>
</Page>
